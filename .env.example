# External API keys
TMDB_API_KEY=
TMDB_READ_ACCESS_TOKEN=
WATCHMODE_API_KEY=
OMDB_API_KEY=
ANTHROPIC_API_KEY=

# Runtime
WATCHTHIS_DB_PATH=data/watchthis.db
WATCHTHIS_LOG_LEVEL=INFO
WATCHTHIS_HTTP_TIMEOUT_SECONDS=12
WATCHTHIS_WATCH_REGION=US
WATCHTHIS_MIN_RELEASE_YEAR=1960
WATCHTHIS_QUALITY_VOTE_COUNT_FLOOR=500
WATCHTHIS_ALLOWED_COUNTRIES=US,GB,KR,JP,FR
WATCHTHIS_RT_MIN_SCORE=75
WATCHTHIS_RT_FALLBACK_SCORE=70
WATCHTHIS_SHORTLIST_SIZE=15
WATCHTHIS_CURATED_CATALOG_ENABLED=true
WATCHTHIS_CURATED_CATALOG_PATH=data/curated_exceptions.md
WATCHTHIS_OMDB_ENRICHMENT_LIMIT=20

# Anthropic
WATCHTHIS_ALLOW_HEURISTIC_FALLBACK=false
WATCHTHIS_HAIKU_MODEL=claude-3-5-haiku-latest
WATCHTHIS_SONNET_MODEL=claude-3-5-sonnet-latest
WATCHTHIS_OPUS_MODEL=claude-opus-4-1
WATCHTHIS_USE_OPUS_FOR_RANKING=false
